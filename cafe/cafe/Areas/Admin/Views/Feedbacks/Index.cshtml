@model IEnumerable<cafe.Models.Feedback>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý phản hồi";
}

<div class="row mb-2">
    <div class="col-sm-6">
        <h1 class="m-0">Phản hồi từ khách hàng</h1>
    </div>
    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Phản hồi</li>
        </ol>
    </div>
</div>
<hr />

<div class="card shadow-sm">
    <div class="card-header border-0">
        <h3 class="card-title">Danh sách ý kiến đóng góp</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-valign-middle">
            <thead>
                <tr>
                    <th>Ngày gửi</th>
                    <th>Người gửi</th>
                    <th>Đánh giá</th>
                    <th style="width: 40%">Nội dung</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Chưa có phản hồi nào.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.User != null)
                                {
                                    <span class="badge badge-info">@item.User.FullName</span>
                                    <br /><small class="text-muted">@item.User.Email</small>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Khách ẩn danh</span>
                                }
                            </td>
                            <td>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="@(i <= item.Rating ? "fas" : "far") fa-star"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <div style="max-height: 100px; overflow-y: auto; white-space: pre-wrap;">@item.Content</div>
                            </td>
                            <td class="text-center">
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa phản hồi này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
