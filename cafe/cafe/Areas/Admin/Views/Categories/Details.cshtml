@model cafe.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-layer-group"></i> @Model.Name</h5>
            @if (Model.IsActive)
            {
                <span class="badge bg-success">Hoạt động</span>
            }
            else
            {
                <span class="badge bg-secondary">Ẩn</span>
            }
        </div>
        <div class="card-body">
            <table class="table table-borderless">
                <tr>
                    <td width="25%" class="fw-bold text-muted"><i class="fas fa-tag me-1"></i> Tên danh mục</td>
                    <td class="fw-bold fs-5">@Model.Name</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted"><i class="fas fa-align-left me-1"></i> Mô tả</td>
                    <td class="text-muted">@(Model.Description ?? "Chưa có mô tả")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted"><i class="fas fa-calendar me-1"></i> Ngày tạo</td>
                    <td>@Model.CreatedDate.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted"><i class="fas fa-toggle-on me-1"></i> Trạng thái</td>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ẩn</span>
                        }
                    </td>
                </tr>
            </table>
        </div>
        <div class="card-footer bg-light d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
            <a asp-action="Index" class="btn btn-secondary ms-auto"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </div>
    </div>
</div>
