
@model X.PagedList.IPagedList<cafe.Models.Category>
@using X.PagedList.Mvc.Core
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="row mb-2">
    <div class="col-sm-6">
        <h1 class="m-0">Category list</h1>
    </div>
    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Home Admin</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Categories" asp-action="Index">Category</a></li>
            <li class="breadcrumb-item active">Category list</li>
        </ol>
    </div>
</div>

<hr />

<div class="row mb-3">

    <div class="col-md-8 offset-md-2">
        <form method="get">
            <div class="input-group">
                <input type="search"
                       name="name"
                       class="form-control form-control-lg"
                       placeholder="Nhập tên danh mục để tìm...">

                <div class="input-group-append">
                    <button type="submit" class="btn btn-lg btn-default">
                        <i class="fa fa-search"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="col-md-2 text-end">
        <a asp-action="Create" class="btn btn-success mt-2">
            <i class="fas fa-plus-circle"></i> Thêm mới
        </a>
    </div>

</div>

<h5 class="my-3">
    <b class="text-success">@TempData["Message"]</b>
    <b class="text-danger">@TempData["MessageError"]</b>
</h5>

<div class="card shadow-sm">
    <div class="card-body">

        <table class="table table-hover table-bordered align-middle">

            <thead class="table-dark text-center">
                <tr>
                    <th>Tên</th>
                    <th>Mô tả</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th width="200">Hành động</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Name</td>

                        <td>@item.Description</td>

                        <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>

                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                        </td>
                        <td class="text-center">

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>

                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i>
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <!-- PHÂN TRANG -->
        <div class="mt-3">

            @Html.PagedListPager(
            Model,
            page => Url.Action("Index", new { page }),
                        new PagedListRenderOptions
                        {
                            LiElementClasses = new List<string> { "page-item" },
                            PageClasses = new List<string> { "page-link" }
                        }
                        )

        </div>

    </div>
</div>