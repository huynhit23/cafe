@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row mb-2">
    <div class="col-sm-6">
        <h1 class="m-0">Bảng điều khiển</h1>
    </div>
    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item active"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        </ol>
    </div>
</div>
<hr />

<div class="row">
    <!-- Total Revenue -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-success shadow-sm">
            <div class="inner">
                <h3>@ViewBag.TotalRevenue.ToString("N0")<sup style="font-size: 20px">đ</sup></h3>
                <p>Tổng doanh thu</p>
            </div>
            <div class="icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="small-box-footer">Chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <!-- Total Orders -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info shadow-sm">
            <div class="inner">
                <h3>@ViewBag.TotalOrders</h3>
                <p>Tổng đơn hàng</p>
            </div>
            <div class="icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="small-box-footer">Chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <!-- Total Products -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning shadow-sm">
            <div class="inner">
                <h3>@ViewBag.TotalProducts</h3>
                <p>Sản phẩm</p>
            </div>
            <div class="icon">
                <i class="fas fa-coffee"></i>
            </div>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="small-box-footer">Chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <!-- Total Users -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger shadow-sm">
            <div class="inner">
                <h3>@ViewBag.TotalUsers</h3>
                <p>Người dùng</p>
            </div>
            <div class="icon">
                <i class="fas fa-users"></i>
            </div>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="small-box-footer">Chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header border-0">
                <h3 class="card-title"><i class="fas fa-chart-pie mr-1"></i> Phân loại hệ thống</h3>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center border-bottom mb-3 pb-2">
                    <span><strong>Danh mục sản phẩm:</strong></span>
                    <span class="badge badge-primary p-2">@ViewBag.TotalCategories</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span><strong>Bài viết (Blog):</strong></span>
                    <span class="badge badge-info p-2">@ViewBag.TotalBlogs</span>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 text-center">
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-primary mr-2">Quản lý danh mục</a>
                <a asp-area="Admin" asp-controller="Blogs" asp-action="Index" class="btn btn-info">Quản lý bài viết</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card card-outline card-secondary shadow-sm">
            <div class="card-header border-0">
                <h3 class="card-title"><i class="fas fa-clock mr-1"></i> Thông báo hệ thống</h3>
            </div>
            <div class="card-body">
                <p class="text-muted">Chào mừng bạn quay lại hệ thống quản trị Providence Cafe.</p>
                <p>Hệ thống hiện đang hoạt động bình thường trên nền tảng .NET Core MVC.</p>
            </div>
        </div>
    </div>
</div>