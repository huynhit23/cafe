@model X.PagedList.IPagedList<cafe.Models.Blog>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Blog list Page";
}

<div class="row mb-2">
    <div class="col-sm-6">
        <h1 class="m-0">Blog list</h1>
    </div>

    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index">Home Admin</a>
            </li>
            <li class="breadcrumb-item active">Blog list</li>
        </ol>
    </div>
</div>

<hr />

<div class="row mb-3">

    <!-- SEARCH -->
    <div class="col-md-8">

        <form method="get">

            <div class="input-group">

                <input type="search"
                       name="title"
                       value="@Context.Request.Query["title"]"
                       class="form-control form-control-lg"
                       placeholder="Enter blog title to search..." />

                <div class="input-group-append">

                    <button type="submit"
                            class="btn btn-lg btn-default">

                        <i class="fa fa-search"></i>

                    </button>

                </div>

            </div>

        </form>

    </div>

    <!-- CREATE -->
    <div class="col-md-4 text-right">

        <a asp-area="Admin"
           asp-controller="Blogs"
           asp-action="Create"
           class="btn btn-primary">

            <i class="fas fa-plus"></i>
            Create

        </a>

    </div>

</div>

<h5 class="my-3">
    <b class="text-success">@TempData["Message"]</b>
</h5>

<table class="table table-bordered table-hover">

    <thead class="thead-dark">

        <tr>

            <th>Title</th>
            <th>Content</th>
            <th>Image</th>
            <th>Created</th>
            <th>Status</th>
            <th width="200">Action</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Title</td>

                <td>
                    @(item.Content.Length > 80
                        ? item.Content.Substring(0, 80) + "..."
                        : item.Content)
                </td>

                <td>

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="~/Images/@item.ImageUrl"
                             width="80"
                             height="60"
                             style="object-fit:cover;border-radius:5px" />
                    }

                </td>

                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>

                <td>

                    @if (item.IsPublished)
                    {
                        <span class="badge badge-success">Published</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">Hidden</span>
                    }

                </td>

                <td class="text-center">

                    <!-- EDIT -->
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">

                        <i class="fas fa-edit"></i>

                    </a>

                    <!-- DETAILS -->
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">

                        <i class="fas fa-eye"></i>

                    </a>

                    <!-- DELETE -->
                    <form asp-action="Delete"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline">

                        <button type="submit"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Delete this blog?')">

                            <i class="fas fa-trash"></i>

                        </button>

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>

<div class="mt-3">

    @Html.PagedListPager(
        Model,
        page => Url.Action("Index", new { page, title = Context.Request.Query["title"] }),
        new PagedListRenderOptions
        {
            LiElementClasses = new List<string> { "page-item" },
            PageClasses = new List<string> { "page-link" }
        })

</div>