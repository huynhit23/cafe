@model cafe.Models.Blog

@{
    ViewData["Title"] = "Blog Details Page";
}

<div>
    <div class="row mb-2">
        <div class="col-sm-6">
            <h1 class="m-0">Blog Details</h1>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index">Home Admin</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Blogs" asp-action="Index">Blog management</a>
                </li>
                <li class="breadcrumb-item active">Blog Details</li>
            </ol>
        </div>
    </div>

    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Content)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Content)
        </dd>

        <dt class="col-sm-2">
            Blog Image
        </dt>
        <dd class="col-sm-10">

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="~/Images/@Model.ImageUrl"
                     width="20%"
                     height="120"
                     style="object-fit:cover;border-radius:5px" />
            }

        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-10">
            @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">

            @if (Model.IsPublished)
            {
                <span class="badge badge-success">Published</span>
            }
            else
            {
                <span class="badge badge-danger">Hidden</span>
            }

        </dd>

    </dl>
</div>

<div>

    <a asp-area="Admin"
       asp-controller="Blogs"
       asp-action="Edit"
       asp-route-id="@Model?.Id"
       class="btn btn-primary">

        Edit

    </a>

    <a asp-area="Admin"
       asp-controller="Blogs"
       asp-action="Index"
       class="btn btn-secondary">

        Back to List

    </a>

</div>