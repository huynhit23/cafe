@model cafe.Models.Blog

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-newspaper"></i> @Model.Title</h5>
            @if (Model.IsPublished)
            {
                <span class="badge bg-success">Đã đăng</span>
            }
            else
            {
                <span class="badge bg-secondary">Nháp</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div style="max-height: 320px; overflow: hidden;">
                <img src="@Model.ImageUrl" alt="@Model.Title"
                     class="w-100" style="object-fit: cover; max-height: 320px;" />
            </div>
        }

        <div class="card-body">
            <div class="d-flex gap-3 text-muted small mb-4">
                <span><i class="fas fa-calendar"></i> @Model.CreatedDate.ToString("dd/MM/yyyy")</span>
            </div>

            <div class="border-top pt-3" style="line-height: 1.8; font-size: 1rem;">
                @Html.Raw(Model.Content)
            </div>
        </div>

        <div class="card-footer bg-light d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Sửa</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="fas fa-trash"></i> Xóa</a>
            <a asp-action="Index" class="btn btn-secondary ms-auto"><i class="fas fa-arrow-left"></i> Quay lại</a>
        </div>
    </div>
</div>
