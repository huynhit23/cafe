@model cafe.Models.Product

@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="fas fa-edit"></i> Sửa sản phẩm: @Model.Name</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">Giá (₫)</label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" />
                                    <span class="input-group-text">₫</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQuantity" class="form-label fw-bold">Tồn kho</label>
                                <input asp-for="StockQuantity" class="form-control" />
                                <span asp-validation-for="StockQuantity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-bold">Kích hoạt sản phẩm</label>
                        </div>
                    </div>

                    
                    <div class="col-md-4">
                        <div class="card border-dashed h-100" style="border: 2px dashed #ccc;">
                            <div class="card-body text-center d-flex flex-column justify-content-center">
                                <p class="fw-bold text-muted mb-2">Ảnh sản phẩm</p>
                                <div class="mb-3">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img id="imagePreview" src="@Model.ImageUrl" alt="@Model.Name"
                                             class="img-fluid rounded mb-2" style="max-height:200px;" />
                                    }
                                    else
                                    {
                                        <div id="uploadPlaceholder">
                                            <i class="fas fa-image fa-3x text-muted mb-2"></i>
                                            <p class="text-muted small">Chưa có ảnh</p>
                                        </div>
                                        <img id="imagePreview" src="" alt="" class="img-fluid rounded mb-2" style="max-height:200px; display:none;" />
                                    }
                                </div>
                                <label class="btn btn-outline-warning w-100" for="imageFile">
                                    <i class="fas fa-sync-alt"></i> Đổi ảnh mới
                                </label>
                                <input type="file" id="imageFile" name="imageFile" accept="image/*" class="d-none" onchange="previewImage(this)" />
                                <small class="text-muted mt-2">Để trống nếu không muốn thay đổi</small>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />
                <button type="submit" class="btn btn-warning text-dark"><i class="fas fa-save"></i> Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    const ph = document.getElementById('uploadPlaceholder');
                    if (ph) ph.style.display = 'none';
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
}
