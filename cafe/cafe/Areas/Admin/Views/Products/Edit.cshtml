@model cafe.Models.Product

@{
    ViewData["Title"] = "Product Edit Page";
}

<div class="row mb-2">
    <div class="col-sm-6">
        <h1 class="m-0">Product Edit</h1>
    </div>

    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index">Home Admin</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Products" asp-action="Index">Product management</a>
            </li>
            <li class="breadcrumb-item active">Product Edit</li>
        </ol>
    </div>
</div>

<hr />

<form asp-area="Admin"
      asp-controller="Products"
      asp-action="Edit"
      method="post"
      enctype="multipart/form-data">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />

    <!-- Name -->
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <!-- Price -->
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <!-- Description -->
    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description"
                  class="form-control"
                  rows="5"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <!-- Image -->
    <div class="form-group">
        <div class="row">

            <div class="col-6">

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="~/Images/@Model.ImageUrl"
                         width="150"
                         height="120"
                         style="object-fit:cover;border-radius:5px" />
                }

            </div>

            <div class="col-6">

                <label>Product Image</label>

                <input type="file"
                       name="ImageFile"
                       class="form-control mb-2" />

                <!-- gửi ảnh cũ -->
                <input type="hidden"
                       name="OldImage"
                       value="@Model.ImageUrl" />

            </div>

        </div>
    </div>

    <!-- Stock -->
    <div class="form-group">
        <label asp-for="StockQuantity"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <!-- Category -->
    <div class="form-group">
        <label asp-for="CategoryId"></label>
        <select asp-for="CategoryId"
                class="form-control"
                asp-items="ViewBag.CategoryId"></select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- Created Date -->
    <div class="form-group">
        <label asp-for="CreatedDate"></label>
        <input asp-for="CreatedDate"
               class="form-control"
               type="datetime-local" />
        <span asp-validation-for="CreatedDate" class="text-danger"></span>
    </div>

    <!-- Status -->
    <div class="form-group form-check">

        <input asp-for="IsActive"
               class="form-check-input" />

        <label asp-for="IsActive"
               class="form-check-label"></label>

    </div>

    <!-- Buttons -->
    <div class="form-group">

        <button type="submit" class="btn btn-primary">
            Save
        </button>

        <a asp-area="Admin"
           asp-controller="Products"
           asp-action="Index"
           class="btn btn-secondary">
            Back
        </a>

    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}