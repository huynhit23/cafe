@model cafe.Models.Product

@{
    ViewData["Title"] = "Product Details Page";
}

<div>
    <div class="row mb-2">
        <div class="col-sm-6">
            <h1 class="m-0">Product Details</h1>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="HomeAdmin" asp-action="Index">Home Admin</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index">Product management</a>
                </li>
                <li class="breadcrumb-item active">Product Details</li>
            </ol>
        </div>
    </div>

    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ImageUrl)
        </dt>
        <dd class="col-sm-10">
            <img src="~/Images/@Model.ImageUrl" width="20%" height="100" />
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StockQuantity)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StockQuantity)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Category.Name)
        </dd>

    </dl>
</div>

<div>
    <a asp-area="Admin"
       asp-controller="Products"
       asp-action="Edit"
       asp-route-id="@Model?.Id"
       class="btn btn-primary">Edit</a>

    <a asp-area="Admin"
       asp-controller="Products"
       asp-action="Index"
       class="btn btn-secondary">Back to List</a>
</div>