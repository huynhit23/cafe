@model IEnumerable<cafe.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- HERO -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content">
                <p class="tagline">☕ Chào mừng đến với</p>
                <h1>Cafe<br/><span style="color:var(--cafe-light)">Providence</span></h1>
                <p>Hương vị cà phê đặc biệt từ những vùng đất nổi tiếng nhất thế giới. Mỗi tách cà phê là một hành trình.</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a class="btn-cafe" asp-controller="Products" asp-action="Index">
                        <i class="fas fa-store"></i> Xem sản phẩm
                    </a>
                    <a class="btn-cafe-outline" asp-controller="Home" asp-action="About"
                       style="border-color:rgba(255,255,255,.5); color:#fff;">
                        <i class="fas fa-info-circle"></i> Giới thiệu
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center d-none d-lg-block" style="position:relative;z-index:1;">
                <div style="font-size:12rem; opacity:.3;">☕</div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="py-5" style="background:var(--cafe-cream);">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Sản phẩm nổi bật</h2>
            <p class="section-subtitle mt-2">Những lựa chọn được yêu thích nhất</p>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var p in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card h-100">
                            <div class="card-img-wrap">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" />
                                }
                                else
                                {
                                    <i class="fas fa-coffee" style="font-size:3rem;color:var(--cafe-light);"></i>
                                }
                            </div>
                            <div class="card-body">
                                <div class="product-category">@p.Category?.Name</div>
                                <div class="product-name">@p.Name</div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="product-price">@p.Price.ToString("N0") ₫</span>
                                    <button class="btn-cafe" style="padding:.4rem .85rem;font-size:.8rem;"
                                            onclick="openQuickCustomize(@p.Id, '@p.Name', '@p.Price', '@p.ImageUrl')">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a asp-controller="Products" asp-action="Index" class="btn-cafe-outline">
                    Xem tất cả sản phẩm <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-coffee fa-3x mb-3 d-block" style="color:var(--cafe-light);"></i>
                <p>Chưa có sản phẩm nào.</p>
            </div>
        }
    </div>
</section>

<!-- WHY US -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Tại sao chọn Providence?</h2>
        </div>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div style="font-size:2.5rem;color:var(--cafe-brown);margin-bottom:1rem;">🌿</div>
                <h5 style="font-weight:700;">Nguyên liệu tự nhiên</h5>
                <p class="text-muted">100% hạt cà phê tươi, không chất bảo quản, không phẩm màu nhân tạo.</p>
            </div>
            <div class="col-md-4">
                <div style="font-size:2.5rem;color:var(--cafe-brown);margin-bottom:1rem;">✈️</div>
                <h5 style="font-weight:700;">Nhập khẩu trực tiếp</h5>
                <p class="text-muted">Nguồn gốc rõ ràng từ Ethiopia, Colombia, Đà Lạt — giao hàng toàn quốc.</p>
            </div>
            <div class="col-md-4">
                <div style="font-size:2.5rem;color:var(--cafe-brown);margin-bottom:1rem;">⭐</div>
                <h5 style="font-weight:700;">Rang tươi mỗi tuần</h5>
                <p class="text-muted">Cà phê được rang trong tuần để đảm bảo độ tươi và hương vị tốt nhất.</p>
            </div>
        </div>
    </div>
</section>
