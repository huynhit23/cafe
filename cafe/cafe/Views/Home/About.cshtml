@{
    ViewData["Title"] = "Giới thiệu";
}

<section class="py-5" style="background:var(--cafe-cream);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div style="font-size:10rem;text-align:center;line-height:1;">☕</div>
            </div>
            <div class="col-lg-6">
                <p class="tagline" style="color:var(--cafe-brown);font-size:.8rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:.75rem;">Câu chuyện của chúng tôi</p>
                <h2 class="section-title mb-3">Cafe Providence</h2>
                <p class="text-muted mb-3">Được thành lập vào năm 2020, Cafe Providence ra đời với niềm đam mê đối với văn hóa cà phê. Chúng tôi tin rằng một tách cà phê ngon không chỉ là thức uống — đó là trải nghiệm, là ký ức, là kết nối.</p>
                <p class="text-muted mb-4">Từ những hạt cà phê được chăm chút kỹ lưỡng từ các nông trại ở Ethiopia, Colombia đến vùng đất đỏ bazan Đà Lạt, chúng tôi mang đến hương vị thuần khiết nhất trong từng tách cà phê.</p>
                <div class="row g-3">
                    <div class="col-6">
                        <div style="padding:1.25rem;background:#fff;border-radius:12px;text-align:center;box-shadow:var(--shadow);">
                            <div style="font-size:2rem;font-weight:800;color:var(--cafe-brown);">500+</div>
                            <div style="color:var(--text-muted);font-size:.85rem;">Khách hàng</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="padding:1.25rem;background:#fff;border-radius:12px;text-align:center;box-shadow:var(--shadow);">
                            <div style="font-size:2rem;font-weight:800;color:var(--cafe-brown);">20+</div>
                            <div style="color:var(--text-muted);font-size:.85rem;">Sản phẩm</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Giá trị cốt lõi</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div style="padding:2rem;border-radius:16px;border:1px solid rgba(107,63,42,.1);height:100%;">
                    <div style="font-size:2rem;margin-bottom:1rem;">🌱</div>
                    <h5 style="font-weight:700;color:var(--cafe-brown);">Bền vững</h5>
                    <p class="text-muted">Hợp tác trực tiếp với nông dân, đảm bảo canh tác có trách nhiệm với môi trường.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div style="padding:2rem;border-radius:16px;background:var(--cafe-brown);color:#fff;height:100%;">
                    <div style="font-size:2rem;margin-bottom:1rem;">❤️</div>
                    <h5 style="font-weight:700;">Tận tâm</h5>
                    <p style="opacity:.8;">Mỗi mẻ rang được kiểm soát chất lượng nghiêm ngặt để đảm bảo hương vị tốt nhất.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div style="padding:2rem;border-radius:16px;border:1px solid rgba(107,63,42,.1);height:100%;">
                    <div style="font-size:2rem;margin-bottom:1rem;">🤝</div>
                    <h5 style="font-weight:700;color:var(--cafe-brown);">Cộng đồng</h5>
                    <p class="text-muted">Xây dựng cộng đồng những người yêu cà phê, chia sẻ kiến thức và đam mê.</p>
                </div>
            </div>
        </div>
    </div>
</section>
