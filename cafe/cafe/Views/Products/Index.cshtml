@model IEnumerable<cafe.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<cafe.Models.Category> ?? new();
    var search = ViewBag.Search as string;
    var selectedCat = ViewBag.SelectedCategory as int?;
}

<section class="py-5" style="background:var(--cafe-cream); min-height:60vh;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Sản phẩm của chúng tôi</h2>
            <p class="section-subtitle mt-2">Khám phá hương vị cà phê từ khắp nơi trên thế giới</p>
        </div>

        <!-- Search & Filter -->
        <div class="mb-4">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    <div class="input-group search-group">
                        <input type="text" id="searchInput" value="@search" class="form-control" placeholder="Tìm kiếm món quà từ hạt cà phê..." />
                        <span class="input-group-text bg-transparent border-start-0" id="searchIcon">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                    </div>
                </div>
                <div class="col-md-4">
                    <select id="categorySelect" class="form-select custom-select">
                        <option value="">-- Tất cả danh mục --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(selectedCat == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2" id="clearFilterContainer" style="display: @(selectedCat.HasValue || !string.IsNullOrEmpty(search) ? "block" : "none")">
                    <button onclick="clearFilters()" class="btn btn-outline-secondary w-100" style="border-radius:30px;">Xóa lọc</button>
                </div>
            </div>
        </div>

        <!-- Product Container -->
        <div id="productContainer" class="position-relative">
            @await Html.PartialAsync("_ProductListPartial", Model)
            
            <!-- Loading Overlay -->
            <div id="loadingOverlay" class="d-none position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start pt-5" 
                 style="background: rgba(255,255,255,0.7); z-index: 10; min-height: 300px;">
                <div class="spinner-border" style="color:var(--cafe-brown);" role="status">
                    <span class="visually-hidden">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .search-group .form-control:focus {
            box-shadow: none;
            border-color: var(--cafe-brown);
        }
        .search-group .form-control:focus + .input-group-text {
            border-color: var(--cafe-brown);
        }
        .custom-select:focus {
            border-color: var(--cafe-brown);
            box-shadow: 0 0 0 0.25rem rgba(107, 63, 42, 0.1);
        }
    </style>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            let timeout = null;

            $('#searchInput').on('keyup', function() {
                clearTimeout(timeout);
                timeout = setTimeout(function() {
                    applyFilters();
                }, 500);
            });

            $('#categorySelect').on('change', function() {
                applyFilters();
            });
        });

        function applyFilters() {
            const search = $('#searchInput').val();
            const catId = $('#categorySelect').val();
            
            if (search || catId) {
                $('#clearFilterContainer').fadeIn();
            } else {
                $('#clearFilterContainer').fadeOut();
            }

            $('#loadingOverlay').removeClass('d-none').addClass('animate__animated animate__fadeIn');
            
            $.ajax({
                url: '/Products/Filter',
                data: { search: search, categoryId: catId },
                success: function(data) {
                    $('#productContainer').html(data);
                },
                complete: function() {
                    $('#loadingOverlay').addClass('d-none');
                }
            });
        }

        function clearFilters() {
            $('#searchInput').val('');
            $('#categorySelect').val('');
            applyFilters();
        }
    </script>
}
    </div>
</section>
