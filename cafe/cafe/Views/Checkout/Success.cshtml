@{
    ViewData["Title"] = "Đặt hàng thành công";
}
<section class="py-5" style="min-height:70vh;display:flex;align-items:center;">
    <div class="container text-center">
        <div style="font-size:4rem;margin-bottom:1rem;">✅</div>
        <h2 style="font-family:'Playfair Display',serif;color:var(--cafe-brown);">Đặt hàng thành công!</h2>
        <p class="text-muted mt-2 mb-4">
            Cảm ơn bạn đã mua hàng tại Cafe Providence.<br/>
            @if (ViewBag.OrderId != null)
            {
                <span>Mã đơn hàng: <strong style="color:var(--cafe-brown);">#@ViewBag.OrderId</strong></span>
            }
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="OrderHistory" asp-action="Index" class="btn-cafe">
                <i class="fas fa-list me-1"></i>Lịch sử đơn hàng
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn-cafe-outline">
                <i class="fas fa-store me-1"></i>Tiếp tục mua sắm
            </a>
        </div>
    </div>
</section>
