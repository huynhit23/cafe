@model List<cafe.Controllers.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
    decimal total = ViewBag.Total ?? 0;
}

<section class="py-5">
    <div class="container">
        <div class="row g-5">

            <!-- Form thông tin -->
            <div class="col-lg-7">
                <h3 style="font-family:'Playfair Display',serif;color:var(--cafe-brown);" class="mb-4">Thông tin giao hàng</h3>
                <form asp-controller="Checkout" asp-action="Confirm" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên nhận hàng</label>
                        <input type="text" class="form-control" value="@User.Identity?.Name" readonly style="background:#f9f9f9;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                        <textarea name="shippingAddress" class="form-control" rows="3"
                                  placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố" required></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Ghi chú</label>
                        <input type="text" class="form-control" placeholder="Giao giờ hành chính, gọi trước khi giao..." />
                    </div>
                    <button type="submit" class="btn-cafe w-100 justify-content-center" style="font-size:1rem;padding:.85rem;">
                        <i class="fas fa-check-circle me-2"></i>Đặt hàng (@total.ToString("N0") ₫)
                    </button>
                </form>
            </div>

            <!-- Đơn hàng -->
            <div class="col-lg-5">
                <div style="background:var(--cafe-cream);border-radius:16px;padding:1.75rem;">
                    <h5 style="font-family:'Playfair Display',serif;color:var(--cafe-brown);" class="mb-3">Đơn hàng của bạn</h5>
                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                            <div class="d-flex gap-2 align-items-center">
                                <img src="@(item.ImageUrl ?? "")" onerror="this.src=''" alt="@item.Name"
                                     style="width:50px;height:50px;border-radius:8px;object-fit:cover;background:var(--cafe-gray);" />
                                <div>
                                    <div style="font-weight:600;font-size:.9rem;">@item.Name</div>
                                    <div style="font-size:.8rem;color:var(--text-muted);">x@item.Quantity</div>
                                </div>
                            </div>
                            <span style="font-weight:700;color:var(--cafe-brown);">@((item.Price * item.Quantity).ToString("N0")) ₫</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mt-2">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="text-success fw-600">Miễn phí</span>
                    </div>
                    <div class="d-flex justify-content-between mt-2 pt-2 border-top">
                        <strong style="font-size:1.1rem;">Tổng cộng</strong>
                        <strong style="font-size:1.2rem;color:var(--cafe-brown);">@total.ToString("N0") ₫</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
