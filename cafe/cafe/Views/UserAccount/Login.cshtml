@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập - Cafe Providence</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg,#2D1B0E,#6B3F2A); min-height:100vh; display:flex; align-items:center; font-family:'Segoe UI',sans-serif; }
        .card { border:none; border-radius:20px; box-shadow:0 20px 60px rgba(0,0,0,.3); }
        .brand { font-size:1.8rem; color:#6B3F2A; font-weight:800; text-decoration:none; }
        .form-control:focus { border-color:#C8956C; box-shadow:0 0 0 3px rgba(200,149,108,.2); }
        .btn-main { background:#6B3F2A; color:#fff; border:none; border-radius:10px; padding:.75rem; font-weight:600; width:100%; }
        .btn-main:hover { background:#2D1B0E; color:#fff; }
        .input-group-text { background:#FDF6EE; border-color:#dee2e6; }
        .alert-err { background:#fdf0ef; border:1px solid #f5c6cb; color:#842029; border-radius:10px; padding:.75rem 1rem; font-size:.87rem; }
    </style>
</head>
<body>
<div class="container" style="max-width:420px;">
    <div class="card p-4 p-md-5">
        <div class="text-center mb-4">
            <a href="/" class="brand">☕ Providence</a>
            <p class="text-muted mt-1" style="font-size:.9rem;">Đăng nhập tài khoản</p>
        </div>

        @if (ViewData["Error"] != null)
        {
            <div class="alert-err mb-3"><i class="fas fa-exclamation-circle me-1"></i>@ViewData["Error"]</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="mb-3">
                <label class="form-label fw-500">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required autofocus />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-500">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="rememberMe" id="rm" />
                    <label class="form-check-label text-muted" for="rm" style="font-size:.85rem;">Ghi nhớ đăng nhập</label>
                </div>
            </div>
            <button type="submit" class="btn-main"><i class="fas fa-sign-in-alt me-2"></i>Đăng nhập</button>
        </form>
        <p class="text-center mt-3 text-muted" style="font-size:.88rem;">
            Chưa có tài khoản? <a asp-controller="UserAccount" asp-action="Register" style="color:#6B3F2A;font-weight:600;">Đăng ký ngay</a>
        </p>
        <p class="text-center" style="font-size:.8rem;"><a href="/" style="color:#8C7B6B;"><i class="fas fa-arrow-left me-1"></i>Quay về trang chủ</a></p>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
